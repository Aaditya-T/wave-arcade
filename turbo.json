{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "NODE_ENV",
    "APP_URL",
    "API_URL",
    "SUPABASE_URL",
    "SUPABASE_PUBLISHABLE_KEY",
    "SUPABASE_SECRET_KEY",
    "SUPABASE_ANON_KEY",
    "SUPABASE_SERVICE_ROLE_KEY",
    "XRPL_NETWORK",
    "XRPL_RPC_URL",
    "XRPL_SOURCE_TAG",
    "XAMAN_API_KEY",
    "XAMAN_API_SECRET",
    "WEB3AUTH_CLIENT_ID",
    "DISCORD_BOT_TOKEN",
    "DISCORD_CLIENT_ID",
    "DISCORD_GUILD_ID",
    "TELEGRAM_BOT_TOKEN",
    "TREASURY_WALLET_ADDRESS",
    "FACTION_CREATION_FEE_XRP",
    "OPENAI_API_KEY"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "api#build": {
      "outputs": []
    },
    "web#build": {
      "outputs": []
    },
    "xapp#build": {
      "outputs": []
    },
    "telegram-bot#build": {
      "outputs": []
    },
    "discord-bot#build": {
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    }
  }
}
